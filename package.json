{
  "name": "claw",
  "private": true,
  "workspaces": [
    "lib/*",
    "web"
  ],
  "scripts": {
    "build": "turbo run build --output-logs=errors-only",
    "check": "lintmax check",
    "clean": "rm -rf bun.lock node_modules .cache **/node_modules **/.cache **/.next **/.turbo **/dist",
    "dev": "turbo watch dev",
    "fix": "lintmax fix && turbo typecheck build --output-logs=errors-only",
    "format": "lintmax fix",
    "prepare": "git config core.hooksPath .githooks",
    "test": "turbo run test",
    "verify": "bun run tsc && bun run check && bun run build"
  },
  "dependencies": {
    "e2b": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "lintmax": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "lintmax"
  ]
}
