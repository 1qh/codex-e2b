{
  "name": "@a/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun run --env-file=../../.env --watch src/index.ts",
    "test": "cd ../.. && ADMIN_SECRET=${ADMIN_SECRET:-test-secret} bun test lib/server/test --timeout 300000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "latest",
    "e2b": "latest",
    "elysia": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  }
}
